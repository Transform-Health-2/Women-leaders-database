# Supabase project credentials
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Admin email addresses are NOT client env vars — they live as Supabase Edge Function Secrets:
#   ADMIN_NOTIFY_EMAIL  — receives self-service action notifications (used by notify-admin action)
#   ADMIN_CC_EMAIL      — CC'd on enrichment emails sent to leaders
# Set these in Supabase Dashboard → Settings → Edge Functions → Secrets
